<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:DebianDialer.Models"
        x:Class="DebianDialer.Views.ContactsWindow"
        Title="Wybierz kontakt"
        Width="350" Height="450"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*, Auto">
        <ListBox x:Name="ContactsList" Grid.Row="0" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Contact">
                    <TextBlock Text="{Binding}" FontSize="16" Padding="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Grid.Row="1" Content="Wybierz" Click="Select_Click" 
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Margin="10" Background="#1E88E5" Foreground="White" FontSize="16"/>
    </Grid>
</Window>
